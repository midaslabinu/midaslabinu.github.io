---
import {
  Mail,
  Globe,
  Twitter,
  GraduationCap,
} from 'lucide-react';

import type { CollectionEntry } from 'astro:content';

interface Props {
  member:
    | CollectionEntry<'team'>
    | CollectionEntry<'people'>;

  // 기존 Team 페이지에서는 /team,
  // MIDAS Lab People 페이지에서는 /people을 전달합니다.
  basePath?: '/team' | '/people';
}

const {
  member,
  basePath = '/team',
} = Astro.props;

const {
  name,
  avatar,
  bio,
  email,
  website,
  linkedin,
  github,
  twitter,
  googleScholar,
} = member.data;

/**
 * Examples:
 *
 * team member:
 * hyundoo-jeong
 *
 * people/current member:
 * current/dongin-kim
 *
 * people/alumni member:
 * alumni/dong-hyun-oh
 *
 * In every case, only the final file-name portion is used.
 */
const memberSlug =
  member.id
    .replace(/\.[^/.]+$/, '')
    .split('/')
    .pop() ?? member.id;

const memberUrl = `${basePath}/${memberSlug}`;

// Color mapping for title badges
const badgeColors = [
  'text-blue-700 bg-blue-50 border-blue-100',
  'text-purple-700 bg-purple-50 border-purple-100',
  'text-emerald-700 bg-emerald-50 border-emerald-100',
  'text-amber-700 bg-amber-50 border-amber-100',
  'text-rose-700 bg-rose-50 border-rose-100',
];
---

<div class="group flex flex-col items-center text-center">
  <!-- Avatar container -->
  <div
    class="relative mb-4 aspect-[4/5] w-48 overflow-hidden rounded-xl bg-gray-100 transition-shadow group-hover:shadow-lg"
  >
    <a
      href={memberUrl}
      class="block h-full w-full"
      aria-label={`View profile of ${name}`}
    >
      <img
        src={avatar.src}
        alt={name}
        class="h-full w-full object-cover object-top transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
    </a>

    <!-- Social overlay -->
    <div
      class="pointer-events-none absolute inset-0 flex items-center justify-center gap-3 bg-black/20 opacity-0 backdrop-blur-[2px] transition-opacity duration-300 group-hover:opacity-100"
    >
      <div class="pointer-events-auto flex flex-wrap justify-center gap-2 px-2">
        {
          email && (
            <a
              href={`mailto:${email}`}
              class="rounded-full bg-white p-2 text-gray-700 transition-all hover:scale-110 hover:text-blue-600"
              title="Email"
              aria-label={`Email ${name}`}
            >
              <Mail className="h-4 w-4" />
            </a>
          )
        }

        {
          website && (
            <a
              href={website}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-full bg-white p-2 text-gray-700 transition-all hover:scale-110 hover:text-blue-600"
              title="Website"
              aria-label={`${name} website`}
            >
              <Globe className="h-4 w-4" />
            </a>
          )
        }

        {
          linkedin && (
            <a
              href={linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-full bg-white p-2 text-gray-700 transition-all hover:scale-110 hover:text-blue-600"
              title="LinkedIn"
              aria-label={`${name} LinkedIn`}
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-4 w-4"
              >
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
                <rect x="2" y="9" width="4" height="12"></rect>
                <circle cx="4" cy="4" r="2"></circle>
              </svg>
            </a>
          )
        }

        {
          github && (
            <a
              href={github}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-full bg-white p-2 text-gray-700 transition-all hover:scale-110 hover:text-blue-600"
              title="GitHub"
              aria-label={`${name} GitHub`}
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-4 w-4"
              >
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
              </svg>
            </a>
          )
        }

        {
          twitter && (
            <a
              href={twitter}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-full bg-white p-2 text-gray-700 transition-all hover:scale-110 hover:text-blue-400"
              title="Twitter"
              aria-label={`${name} Twitter`}
            >
              <Twitter className="h-4 w-4" />
            </a>
          )
        }

        {
          googleScholar && (
            <a
              href={googleScholar}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-full bg-white p-2 text-gray-700 transition-all hover:scale-110 hover:text-blue-600"
              title="Google Scholar"
              aria-label={`${name} Google Scholar`}
            >
              <GraduationCap className="h-4 w-4" />
            </a>
          )
        }
      </div>
    </div>
  </div>

  <!-- Member information -->
  <a
    href={memberUrl}
    class="mb-2 decoration-blue-600 underline-offset-2 hover:underline"
  >
    <h3 class="text-lg font-semibold text-gray-900">
      {name}
    </h3>
  </a>

  {
    member.data.title &&
      member.data.title.length > 0 && (
        <div class="mb-3 flex flex-wrap justify-center gap-2 px-2">
          {member.data.title.map((item, index) => (
            <span
              class={`inline-block rounded-full border px-2 py-0.5 text-xs font-medium ${
                badgeColors[index % badgeColors.length]
              }`}
            >
              {item}
            </span>
          ))}
        </div>
      )
  }

  {
    bio && (
      <p class="line-clamp-2 px-2 text-sm text-gray-500">
        {bio}
      </p>
    )
  }
</div>