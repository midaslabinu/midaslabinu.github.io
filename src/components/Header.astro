---
import { SITE, LOGO_IMAGE } from '../config';
import {
  Menu,
  X,
  Globe,
  ChevronDown,
  Check,
  Search,
} from 'lucide-react';

import { defaultLang, languages } from '../i18n/ui';

const { nav, i18n, customPages } = SITE;
---

<header
  id="site-header"
  data-default-lang={defaultLang}
  class="sticky top-0 z-50 w-full border-b border-gray-100 bg-white/80 backdrop-blur-md transition-colors duration-300"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo and lab name -->
      <div class="flex items-center gap-3">
        <a href="/" class="group flex items-center gap-2">
          {
            LOGO_IMAGE.enable && SITE.logo && (
              <img
                src={SITE.logo}
                alt="MIDAS Lab logo"
                class="h-8 w-8 object-contain"
              />
            )
          }

          <div
            class="flex flex-col leading-tight sm:flex-row sm:items-end sm:gap-2"
          >
            <span
              class="text-lg font-bold leading-tight text-gray-900 transition-colors group-hover:text-blue-600"
            >
              {SITE.labName}
            </span>

            <span
              class="hidden pb-0.5 text-sm font-light text-gray-500 sm:inline"
            >
              {SITE.university}
            </span>
          </div>
        </a>
      </div>

      <!-- Desktop navigation -->
      <nav
        class="hidden items-center gap-6 md:flex"
        aria-label="Main navigation"
      >
        {
          nav.map((item) => {
            if (item.key === 'search') {
              return (
                <a
                  href={item.link}
                  class="rounded-full p-2 text-gray-600 transition-colors hover:bg-gray-50 hover:text-blue-600"
                  aria-label={item.text}
                >
                  <Search className="h-5 w-5" />
                </a>
              );
            }

            if (item.children?.length) {
              return (
                <div class="group relative">
                  <div class="flex items-center">
                    <a
                      href={item.link}
                      class="py-5 text-sm font-medium text-gray-600 transition-colors hover:text-blue-600 focus:text-blue-600 focus:outline-none"
                      data-i18n-key={`nav.${item.key}`}
                    >
                      {item.text}
                    </a>

                    <ChevronDown
                      className="ml-1 h-3.5 w-3.5 text-gray-400 transition-transform duration-200 group-hover:rotate-180 group-focus-within:rotate-180"
                      aria-hidden="true"
                    />
                  </div>

                  <!-- Desktop dropdown -->
                  <div
                    class="invisible absolute left-1/2 top-full z-50 w-64 -translate-x-1/2 translate-y-2 pt-2 opacity-0 transition-all duration-200 group-hover:visible group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:visible group-focus-within:translate-y-0 group-focus-within:opacity-100"
                  >
                    <div
                      class="overflow-hidden rounded-xl border border-gray-100 bg-white py-2 shadow-xl"
                    >
                      {item.children.map((child) => (
                        <a
                          href={child.link}
                          class="block px-4 py-2.5 text-sm text-gray-600 transition-colors hover:bg-blue-50 hover:text-blue-600 focus:bg-blue-50 focus:text-blue-600 focus:outline-none"
                        >
                          {child.text}
                        </a>
                      ))}
                    </div>
                  </div>
                </div>
              );
            }

            return (
              <a
                href={item.link}
                class="py-5 text-sm font-medium text-gray-600 transition-colors hover:text-blue-600 focus:text-blue-600 focus:outline-none"
                data-i18n-key={`nav.${item.key}`}
              >
                {item.text}
              </a>
            );
          })
        }

        {
          customPages?.map((item) => (
            <a
              href={item.link}
              class="py-5 text-sm font-medium text-gray-600 transition-colors hover:text-blue-600 focus:text-blue-600 focus:outline-none"
              data-i18n-key={item.key}
            >
              {item.text}
            </a>
          ))
        }

        {
          i18n.enabled && (
            <div class="group relative ml-2">
              <button
                type="button"
                class="flex items-center gap-1 rounded-full bg-gray-50 px-3 py-2 text-gray-600 outline-none transition-colors hover:bg-gray-100"
                aria-label="Select language"
              >
                <Globe className="h-4 w-4" />

                <span
                  id="current-lang-label"
                  class="text-xs font-medium uppercase"
                >
                  EN
                </span>

                <ChevronDown className="h-3 w-3 opacity-50" />
              </button>

              <div
                class="invisible absolute right-0 w-40 translate-y-2 pt-2 opacity-0 transition-all duration-200 group-hover:visible group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:visible group-focus-within:translate-y-0 group-focus-within:opacity-100"
              >
                <div
                  class="rounded-xl border border-gray-100 bg-white py-2 shadow-xl"
                >
                  {
                    Object.entries(languages).map(([code, label]) => (
                      <button
                        type="button"
                        class="lang-option group/item flex w-full items-center justify-between px-4 py-2 text-left text-sm text-gray-600 transition-colors hover:bg-blue-50 hover:text-blue-600"
                        data-lang={code}
                      >
                        <span>{label}</span>

                        <Check
                          className="h-4 w-4 text-blue-600 opacity-0 transition-opacity group-[.active]/item:opacity-100"
                        />
                      </button>
                    ))
                  }
                </div>
              </div>
            </div>
          )
        }
      </nav>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        type="button"
        class="relative z-[80] -mr-2 rounded-lg p-2 text-gray-600 transition-colors hover:bg-gray-100 md:hidden"
        aria-label="Toggle menu"
        aria-controls="mobile-menu"
        aria-expanded="false"
        onclick="window.toggleMobileMenu(event)"
      >
        <span class="icon-menu block transition-transform duration-300">
          <Menu className="h-6 w-6" />
        </span>

        <span
          class="icon-close absolute inset-0 hidden rotate-90 items-center justify-center transition-transform duration-300"
        >
          <X className="h-6 w-6" />
        </span>
      </button>
    </div>
  </div>

  <!-- Mobile navigation overlay -->
  <div
    id="mobile-menu"
    class="fixed inset-0 z-[100] hidden h-screen w-screen flex-col bg-white md:hidden"
    style="display: none;"
    role="dialog"
    aria-modal="true"
    aria-hidden="true"
    aria-labelledby="mobile-menu-title"
  >
    <!-- Mobile menu header -->
    <div
      class="flex h-20 shrink-0 items-center justify-between border-b border-gray-100 bg-white px-6"
    >
      <div class="flex items-center gap-3">
        {
          LOGO_IMAGE.enable && SITE.logo && (
            <img
              src={SITE.logo}
              alt="MIDAS Lab logo"
              class="h-10 w-10 object-contain"
            />
          )
        }

        <span
          id="mobile-menu-title"
          class="text-xl font-bold text-gray-900"
        >
          {SITE.labName}
        </span>
      </div>

      <button
        type="button"
        onclick="window.closeMobileMenu()"
        class="-mr-2 rounded-full p-2 text-gray-600 transition-colors hover:bg-gray-100"
        aria-label="Close menu"
      >
        <X className="h-8 w-8" />
      </button>
    </div>

    <!-- Mobile menu content -->
    <nav
      class="flex flex-1 flex-col gap-1 overflow-y-auto bg-white px-6 py-8"
      aria-label="Mobile navigation"
    >
      {
        nav.map((item) =>
          item.children?.length ? (
            <div
              class="mobile-nav-group border-b border-gray-100"
              data-mobile-nav-group
            >
              <div class="flex items-center">
                <!--
                  Tapping the menu label opens the main page.
                  Only the arrow button expands or collapses the submenu.
                -->
                <a
                  href={item.link}
                  class="flex min-h-14 flex-1 items-center rounded-l-xl px-4 py-4 text-lg font-medium text-gray-800 transition-all hover:bg-gray-50 hover:text-blue-600"
                  data-i18n-key={`nav.${item.key}`}
                >
                  {item.text}
                </a>

                <button
                  type="button"
                  class="mobile-submenu-toggle flex min-h-14 min-w-14 items-center justify-center rounded-r-xl text-gray-500 transition-colors hover:bg-gray-50 hover:text-blue-600"
                  aria-expanded="false"
                  aria-controls={`mobile-submenu-${item.key}`}
                  aria-label={`Toggle ${item.text} submenu`}
                >
                  <ChevronDown
                    className="mobile-nav-chevron h-5 w-5 shrink-0 transition-transform duration-200"
                    aria-hidden="true"
                  />
                </button>
              </div>

              <div
                id={`mobile-submenu-${item.key}`}
                class="mobile-submenu hidden pb-3"
              >
                <div class="ml-4 border-l-2 border-blue-100 pl-3">
                  {item.children.map((child) => (
                    <a
                      href={child.link}
                      class="block rounded-lg px-4 py-3 text-base text-gray-600 transition-colors hover:bg-blue-50 hover:text-blue-600"
                    >
                      {child.text}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a
              href={item.link}
              class="flex w-full items-center rounded-xl border-b border-gray-100 px-4 py-4 text-lg font-medium text-gray-800 transition-all hover:bg-gray-50 hover:text-blue-600"
              data-i18n-key={`nav.${item.key}`}
            >
              <span>{item.text}</span>
            </a>
          )
        )
      }

      {
        customPages?.map((item) => (
          <a
            href={item.link}
            class="flex w-full items-center rounded-xl border-b border-gray-100 px-4 py-4 text-lg font-medium text-gray-800 transition-all hover:bg-gray-50 hover:text-blue-600"
            data-i18n-key={item.key}
          >
            <span>{item.text}</span>
          </a>
        ))
      }

      {
        i18n.enabled && (
          <div class="mt-8 border-t border-gray-100 pt-6">
            <div
              class="mb-4 px-2 text-sm font-bold uppercase tracking-wider text-gray-500"
            >
              Language
            </div>

            <div class="grid grid-cols-2 gap-3">
              {
                Object.entries(languages).map(([code, label]) => (
                  <button
                    type="button"
                    class="lang-option mobile-lang-option rounded-xl border border-gray-200 px-4 py-3 text-center text-base font-medium text-gray-600 transition-all hover:border-blue-600 hover:bg-blue-50 hover:text-blue-600"
                    data-lang={code}
                    onclick="window.setLanguage && window.setLanguage(this.getAttribute('data-lang')); window.closeMobileMenu()"
                  >
                    {label}
                  </button>
                ))
              }
            </div>
          </div>
        )
      }
    </nav>

    <!-- Mobile menu footer -->
    <div class="shrink-0 border-t border-gray-200 bg-gray-50 p-8">
      <p class="text-center text-sm font-medium text-gray-500">
        © {new Date().getFullYear()} {SITE.labName}
      </p>
    </div>
  </div>
</header>

<style>
  .mobile-nav-group.is-open .mobile-nav-chevron {
    transform: rotate(180deg);
  }
</style>

<script is:inline>
  (function () {
    const header = document.getElementById('site-header');
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const iconMenu = document.querySelector('.icon-menu');
    const iconClose = document.querySelector('.icon-close');
    const langLabel = document.getElementById('current-lang-label');

    let lastFocusedEl = null;

    function setAria(open) {
      btn?.setAttribute('aria-expanded', open ? 'true' : 'false');
      menu?.setAttribute('aria-hidden', open ? 'false' : 'true');
    }

    function closeMobileSubmenu(group) {
      const toggle = group.querySelector('.mobile-submenu-toggle');
      const submenu = group.querySelector('.mobile-submenu');

      group.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
      submenu?.classList.add('hidden');
    }

    function openMobileSubmenu(group) {
      const toggle = group.querySelector('.mobile-submenu-toggle');
      const submenu = group.querySelector('.mobile-submenu');

      group.classList.add('is-open');
      toggle?.setAttribute('aria-expanded', 'true');
      submenu?.classList.remove('hidden');
    }

    function closeMobileSubmenus(exceptGroup = null) {
      menu
        ?.querySelectorAll('[data-mobile-nav-group]')
        .forEach((group) => {
          if (group !== exceptGroup) {
            closeMobileSubmenu(group);
          }
        });
    }

    function trapFocus(event) {
      if (
        !menu ||
        !menu.contains(document.activeElement) ||
        event.key !== 'Tab'
      ) {
        return;
      }

      const focusable = menu.querySelectorAll(
        'a, button, input, [tabindex]:not([tabindex="-1"])'
      );

      if (!focusable.length) {
        return;
      }

      const first = focusable[0];
      const last = focusable[focusable.length - 1];

      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
    }

    function onKeydown(event) {
      if (event.key === 'Escape') {
        window.closeMobileMenu();
      } else {
        trapFocus(event);
      }
    }

    function openMenu() {
      if (menu) {
        menu.style.display = 'flex';
        menu.offsetHeight;
        menu.classList.remove('hidden');

        menu.animate([{ opacity: 0 }, { opacity: 1 }], {
          duration: 200,
          fill: 'forwards',
          easing: 'ease-out',
        });
      }

      iconMenu?.classList.add('rotate-90', 'opacity-0');
      iconClose?.classList.remove('hidden', 'rotate-90');

      document.body.classList.add('overflow-hidden');
      setAria(true);

      lastFocusedEl = document.activeElement;

      const firstFocusable = menu?.querySelector(
        'a, button'
      );
      firstFocusable?.focus?.();

      document.addEventListener('keydown', onKeydown);
    }

    window.closeMobileMenu = function () {
      if (menu) {
        const animation = menu.animate(
          [{ opacity: 1 }, { opacity: 0 }],
          {
            duration: 200,
            fill: 'forwards',
            easing: 'ease-in',
          }
        );

        animation.onfinish = () => {
          menu.style.display = 'none';
          menu.classList.add('hidden');
          closeMobileSubmenus();
        };
      }

      iconMenu?.classList.remove('rotate-90', 'opacity-0');
      iconClose?.classList.add('rotate-90');

      setTimeout(() => {
        iconClose?.classList.add('hidden');
      }, 200);

      document.body.classList.remove('overflow-hidden');
      setAria(false);

      document.removeEventListener('keydown', onKeydown);

      if (
        lastFocusedEl &&
        typeof lastFocusedEl.focus === 'function'
      ) {
        lastFocusedEl.focus();
      } else {
        btn?.focus?.();
      }
    };

    window.toggleMobileMenu = function (event) {
      event?.stopPropagation();

      if (!menu) {
        return;
      }

      const isHidden =
        menu.style.display === 'none' ||
        menu.classList.contains('hidden');

      if (isHidden) {
        openMenu();
      } else {
        window.closeMobileMenu();
      }
    };

    /*
     * 모바일에서는 메뉴 이름은 해당 페이지로 이동하고,
     * 오른쪽 화살표 버튼만 하위 메뉴를 펼치거나 접습니다.
     * 하나의 하위 메뉴를 열면 나머지는 자동으로 닫습니다.
     */
    menu
      ?.querySelectorAll('[data-mobile-nav-group]')
      .forEach((group) => {
        const toggle = group.querySelector('.mobile-submenu-toggle');

        toggle?.addEventListener('click', (event) => {
          event.preventDefault();
          event.stopPropagation();

          const isOpen = group.classList.contains('is-open');

          if (isOpen) {
            closeMobileSubmenu(group);
          } else {
            closeMobileSubmenus(group);
            openMobileSubmenu(group);
          }
        });
      });

    /*
     * 실제 페이지 또는 앵커 링크를 선택했을 때 모바일 메뉴를 닫습니다.
     */
    menu?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', window.closeMobileMenu);
    });

    function updateHeaderLang(lang) {
      if (langLabel) {
        langLabel.textContent = lang.toUpperCase();
      }

      document.querySelectorAll('.lang-option').forEach((button) => {
        const buttonLang = button.getAttribute('data-lang');

        if (buttonLang === lang) {
          button.classList.add(
            'active',
            'text-blue-600',
            'bg-blue-50',
            'border-blue-200'
          );
        } else {
          button.classList.remove(
            'active',
            'text-blue-600',
            'bg-blue-50',
            'border-blue-200'
          );
        }
      });
    }

    window.addEventListener('language-change', (event) => {
      updateHeaderLang(event.detail.lang);
    });

    try {
      const saved =
        localStorage.getItem('preferred-lang') ||
        header?.dataset.defaultLang ||
        'en';

      updateHeaderLang(saved);
    } catch {
      updateHeaderLang(header?.dataset.defaultLang || 'en');
    }

    document
      .querySelectorAll('.lang-option:not(.mobile-lang-option)')
      .forEach((button) => {
        button.addEventListener('click', () => {
          const lang = button.getAttribute('data-lang');

          if (window.setLanguage && lang) {
            window.setLanguage(lang);
          }
        });
      });

    window.addEventListener('resize', () => {
      if (window.innerWidth >= 768) {
        window.closeMobileMenu();
      }
    });
  })();
</script>
