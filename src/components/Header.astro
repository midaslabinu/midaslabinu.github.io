---
import { SITE, LOGO_IMAGE } from '../config';
import {
  Menu,
  X,
  Globe,
  ChevronDown,
  Check,
  Home,
  BookOpen,
  Trophy,
  Users,
  Calendar,
  UserPlus,
  Sparkles,
  Search,
} from 'lucide-react';

import { defaultLang, languages } from '../i18n/ui';

const { nav, i18n, customPages } = SITE;

const iconMap: Record<string, any> = {
  home: Home,
  research: BookOpen,
  achievements: Trophy,
  team: Users,
  activities: Calendar,
  join: UserPlus,
  search: Search,
};

const getIcon = (key: string) => iconMap[key] || Sparkles;
---

<header
  class="sticky top-0 z-50 w-full border-b border-gray-100 bg-white/80 backdrop-blur-md transition-colors duration-300"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo and lab name -->
      <div class="flex items-center gap-3">
        <a href="/" class="group flex items-center gap-2">
          {
            LOGO_IMAGE.enable && SITE.logo && (
              <img
                src={SITE.logo}
                alt="MIDAS Lab logo"
                class="h-8 w-8 object-contain"
              />
            )
          }

          <div
            class="flex flex-col leading-tight sm:flex-row sm:items-end sm:gap-2"
          >
            <span
              class="text-lg font-bold leading-tight text-gray-900 transition-colors group-hover:text-blue-600"
            >
              {SITE.labName}
            </span>

            <span
              class="hidden pb-0.5 text-sm font-light text-gray-500 sm:inline"
            >
              {SITE.university}
            </span>
          </div>
        </a>
      </div>

      <!-- Desktop navigation -->
      <nav class="hidden items-center gap-6 md:flex">
        {
          nav.map((item) => {
            if (item.key === 'search') {
              return (
                <a
                  href={item.link}
                  class="rounded-full p-2 text-gray-600 transition-colors hover:bg-gray-50 hover:text-blue-600"
                  aria-label={item.text}
                >
                  <Search className="h-5 w-5" />
                </a>
              );
            }

            return (
              <a
                href={item.link}
                class="text-sm font-medium text-gray-600 transition-colors hover:text-blue-600"
                data-i18n-key={`nav.${item.key}`}
              >
                {item.text}
              </a>
            );
          })
        }

        {
          customPages?.map((item) => (
            <a
              href={item.link}
              class="text-sm font-medium text-gray-600 transition-colors hover:text-blue-600"
              data-i18n-key={item.key}
            >
              {item.text}
            </a>
          ))
        }

        {
          i18n.enabled && (
            <div class="group relative ml-2">
              <button
                type="button"
                class="flex items-center gap-1 rounded-full bg-gray-50 px-3 py-2 text-gray-600 outline-none transition-colors hover:bg-gray-100"
                aria-label="Select language"
              >
                <Globe className="h-4 w-4" />

                <span
                  id="current-lang-label"
                  class="text-xs font-medium uppercase"
                >
                  EN
                </span>

                <ChevronDown className="h-3 w-3 opacity-50" />
              </button>

              <!-- Language dropdown -->
              <div
                class="absolute right-0 hidden w-40 origin-top-right pt-2 transition-all group-hover:block"
              >
                <div
                  class="rounded-xl border border-gray-100 bg-white py-2 shadow-xl"
                >
                  {
                    Object.entries(languages).map(([code, label]) => (
                      <button
                        type="button"
                        class="lang-option group/item flex w-full items-center justify-between px-4 py-2 text-left text-sm text-gray-600 transition-colors hover:bg-blue-50 hover:text-blue-600"
                        data-lang={code}
                      >
                        <span>{label}</span>

                        <Check
                          className="h-4 w-4 text-blue-600 opacity-0 transition-opacity group-[.active]/item:opacity-100"
                        />
                      </button>
                    ))
                  }
                </div>
              </div>
            </div>
          )
        }
      </nav>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        type="button"
        class="relative z-[80] -mr-2 rounded-lg p-2 text-gray-600 transition-colors hover:bg-gray-100 md:hidden"
        aria-label="Toggle menu"
        aria-controls="mobile-menu"
        aria-expanded="false"
        onclick="window.toggleMobileMenu(event)"
      >
        <span
          class="icon-menu block transition-transform duration-300"
        >
          <Menu className="h-6 w-6" />
        </span>

        <span
          class="icon-close absolute inset-0 hidden rotate-90 items-center justify-center transition-transform duration-300"
        >
          <X className="h-6 w-6" />
        </span>
      </button>
    </div>
  </div>

  <!-- Mobile navigation overlay -->
  <div
    id="mobile-menu"
    class="fixed inset-0 z-[100] hidden h-screen w-screen flex-col bg-white md:hidden"
    style="display: none;"
    role="dialog"
    aria-modal="true"
    aria-hidden="true"
    aria-labelledby="mobile-menu-title"
  >
    <!-- Mobile menu header -->
    <div
      class="flex h-20 shrink-0 items-center justify-between border-b border-gray-100 bg-white px-6"
    >
      <div class="flex items-center gap-3">
        {
          LOGO_IMAGE.enable && SITE.logo && (
            <img
              src={SITE.logo}
              alt="MIDAS Lab logo"
              class="h-10 w-10 object-contain"
            />
          )
        }

        <span
          id="mobile-menu-title"
          class="text-xl font-bold text-gray-900"
        >
          {SITE.labName}
        </span>
      </div>

      <button
        type="button"
        onclick="window.closeMobileMenu()"
        class="-mr-2 rounded-full p-2 text-gray-600 transition-colors hover:bg-gray-100"
        aria-label="Close menu"
      >
        <X className="h-8 w-8" />
      </button>
    </div>

    <!-- Mobile menu content -->
    <nav
      class="flex flex-1 flex-col gap-2 overflow-y-auto bg-white px-6 py-8"
    >
      {
        nav.map((item) => (
          <a
            href={item.link}
            class="flex w-full items-center rounded-xl border-b border-gray-100 px-4 py-4 text-lg font-medium text-gray-800 transition-all hover:bg-gray-50 hover:text-blue-600 last:border-0"
            data-i18n-key={`nav.${item.key}`}
            onclick="window.closeMobileMenu()"
          >
            <span>{item.text}</span>
          </a>
        ))
      }

      {
        customPages?.map((item) => (
          <a
            href={item.link}
            class="flex w-full items-center rounded-xl border-b border-gray-100 px-4 py-4 text-lg font-medium text-gray-800 transition-all hover:bg-gray-50 hover:text-blue-600 last:border-0"
            data-i18n-key={item.key}
            onclick="window.closeMobileMenu()"
          >
            <span>{item.text}</span>
          </a>
        ))
      }

      {
        i18n.enabled && (
          <div class="mt-8 border-t border-gray-100 pt-6">
            <div
              class="mb-4 px-2 text-sm font-bold uppercase tracking-wider text-gray-500"
            >
              Language
            </div>

            <div class="grid grid-cols-2 gap-3">
              {
                Object.entries(languages).map(([code, label]) => (
                  <button
                    type="button"
                    class="lang-option mobile-lang-option rounded-xl border border-gray-200 px-4 py-3 text-center text-base font-medium text-gray-600 transition-all hover:border-blue-600 hover:bg-blue-50 hover:text-blue-600"
                    data-lang={code}
                    onclick="window.setLanguage && window.setLanguage(this.getAttribute('data-lang')); window.closeMobileMenu()"
                  >
                    {label}
                  </button>
                ))
              }
            </div>
          </div>
        )
      }
    </nav>

    <!-- Mobile menu footer -->
    <div
      class="shrink-0 border-t border-gray-200 bg-gray-50 p-8"
    >
      <p
        class="text-center text-sm font-medium text-gray-500"
      >
        © {new Date().getFullYear()} {SITE.labName}
      </p>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const iconMenu = document.querySelector('.icon-menu');
    const iconClose = document.querySelector('.icon-close');
    const langLabel = document.getElementById(
      'current-lang-label'
    );

    let lastFocusedEl = null;

    function setAria(open) {
      btn?.setAttribute(
        'aria-expanded',
        open ? 'true' : 'false'
      );

      menu?.setAttribute(
        'aria-hidden',
        open ? 'false' : 'true'
      );
    }

    function trapFocus(event) {
      if (
        !menu ||
        !menu.contains(document.activeElement) ||
        event.key !== 'Tab'
      ) {
        return;
      }

      const focusable = menu.querySelectorAll(
        'a, button, input, [tabindex]:not([tabindex="-1"])'
      );

      if (!focusable.length) {
        return;
      }

      const first = focusable[0];
      const last = focusable[focusable.length - 1];

      if (
        event.shiftKey &&
        document.activeElement === first
      ) {
        event.preventDefault();
        last.focus();
      } else if (
        !event.shiftKey &&
        document.activeElement === last
      ) {
        event.preventDefault();
        first.focus();
      }
    }

    function onKeydown(event) {
      if (event.key === 'Escape') {
        window.closeMobileMenu();
      } else {
        trapFocus(event);
      }
    }

    function openMenu() {
      if (menu) {
        menu.style.display = 'flex';
        menu.offsetHeight;
        menu.classList.remove('hidden');

        menu.animate(
          [
            { opacity: 0 },
            { opacity: 1 },
          ],
          {
            duration: 200,
            fill: 'forwards',
            easing: 'ease-out',
          }
        );
      }

      iconMenu?.classList.add(
        'rotate-90',
        'opacity-0'
      );

      iconClose?.classList.remove(
        'hidden',
        'rotate-90'
      );

      document.body.classList.add('overflow-hidden');
      setAria(true);

      lastFocusedEl = document.activeElement;

      const firstLink = menu?.querySelector('a');
      firstLink?.focus?.();

      document.addEventListener(
        'keydown',
        onKeydown
      );
    }

    window.closeMobileMenu = function () {
      if (menu) {
        const animation = menu.animate(
          [
            { opacity: 1 },
            { opacity: 0 },
          ],
          {
            duration: 200,
            fill: 'forwards',
            easing: 'ease-in',
          }
        );

        animation.onfinish = () => {
          menu.style.display = 'none';
          menu.classList.add('hidden');
        };
      }

      iconMenu?.classList.remove(
        'rotate-90',
        'opacity-0'
      );

      iconClose?.classList.add('rotate-90');

      setTimeout(() => {
        iconClose?.classList.add('hidden');
      }, 200);

      document.body.classList.remove(
        'overflow-hidden'
      );

      setAria(false);

      document.removeEventListener(
        'keydown',
        onKeydown
      );

      if (
        lastFocusedEl &&
        typeof lastFocusedEl.focus === 'function'
      ) {
        lastFocusedEl.focus();
      } else {
        btn?.focus?.();
      }
    };

    window.toggleMobileMenu = function (event) {
      event?.stopPropagation();

      if (!menu) {
        return;
      }

      const isHidden =
        menu.style.display === 'none' ||
        menu.classList.contains('hidden');

      if (isHidden) {
        openMenu();
      } else {
        window.closeMobileMenu();
      }
    };

    menu
      ?.querySelectorAll('a')
      .forEach((link) => {
        link.addEventListener(
          'click',
          window.closeMobileMenu
        );
      });

    function updateHeaderLang(lang) {
      if (langLabel) {
        langLabel.textContent =
          lang.toUpperCase();
      }

      document
        .querySelectorAll('.lang-option')
        .forEach((button) => {
          const buttonLang =
            button.getAttribute('data-lang');

          if (buttonLang === lang) {
            button.classList.add(
              'text-blue-600',
              'bg-blue-50',
              'border-blue-200'
            );
          } else {
            button.classList.remove(
              'text-blue-600',
              'bg-blue-50',
              'border-blue-200'
            );
          }
        });
    }

    window.addEventListener(
      'language-change',
      (event) => {
        updateHeaderLang(event.detail.lang);
      }
    );

    try {
      const saved =
        localStorage.getItem('preferred-lang') ||
        defaultLang;

      updateHeaderLang(saved);
    } catch {}

    document
      .querySelectorAll(
        '.lang-option:not(.mobile-lang-option)'
      )
      .forEach((button) => {
        button.addEventListener('click', () => {
          const lang =
            button.getAttribute('data-lang');

          if (window.setLanguage) {
            window.setLanguage(lang);
          }
        });
      });

    window.addEventListener('resize', () => {
      if (window.innerWidth >= 768) {
        window.closeMobileMenu();
      }
    });
  })();
</script>