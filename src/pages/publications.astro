---
import Layout from '../layouts/Layout.astro';
import PublicationItem from '../components/PublicationItem.astro';
import { getCollection } from 'astro:content';
import { ArrowUp } from 'lucide-react';

const allPublications = (await getCollection('publications')).sort(
  (a, b) => {
    const yearDifference = b.data.year - a.data.year;

    if (yearDifference !== 0) {
      return yearDifference;
    }

    return a.data.title.localeCompare(b.data.title);
  }
);

const categories = [
  {
    id: 'journal',
    label: 'Journal Articles',
    description: 'Peer-reviewed journal articles',
  },
  {
    id: 'conference',
    label: 'Conference Papers',
    description: 'Conference papers and proceedings',
  },
  {
    id: 'patent',
    label: 'Patents',
    description: 'Registered and pending patents',
  },
  {
    id: 'book',
    label: 'Books',
    description: 'Books and book chapters',
  },
] as const;

type CategoryId = (typeof categories)[number]['id'];

const getCategoryFromId = (id: string): CategoryId => {
  const directoryName = id
    .replace(/\.[^/.]+$/, '')
    .split('/')[0]
    ?.toLowerCase();

  const category = categories.find(
    (item) => item.id === directoryName
  );

  // publications/ 바로 아래에 있는 기존 파일은
  // 임시로 journal에 포함합니다.
  return category?.id ?? 'journal';
};

const getPublicationsByCategory = (
  categoryId: CategoryId
) =>
  allPublications.filter(
    (publication) =>
      getCategoryFromId(publication.id) === categoryId
  );
---

<Layout title="Publications">
  <main
    id="publication-page-top"
    class="mx-auto max-w-5xl px-4 py-12 sm:py-20"
  >
    <!-- Page header -->
    <header class="mb-12">
      <h1 class="mb-4 text-4xl font-bold text-gray-900">
        Publications
      </h1>

      <p class="max-w-3xl text-lg leading-8 text-gray-600">
        A collection of our journal articles, conference papers,
        patents, and books.
      </p>
    </header>

    <!-- Category navigation -->
    <nav
      aria-label="Publication categories"
      class="mb-16 rounded-2xl border border-gray-100 bg-white p-4 shadow-sm sm:p-5"
    >
      <div
        class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4"
      >
        {
          categories.map((category) => {
            const publications =
              getPublicationsByCategory(category.id);

            return (
              <a
                href={`#${category.id}`}
                class="group flex items-center justify-between rounded-xl bg-gray-50 px-4 py-3 text-sm font-medium text-gray-700 transition-colors hover:bg-blue-50 hover:text-blue-600"
              >
                <span>{category.label}</span>

                <span
                  class="ml-3 min-w-7 rounded-full border border-gray-200 bg-white px-2 py-0.5 text-center text-xs text-gray-500 shadow-sm transition-colors group-hover:border-blue-200 group-hover:text-blue-600"
                >
                  {publications.length}
                </span>
              </a>
            );
          })
        }
      </div>
    </nav>

    <!-- Category sections -->
    <div class="space-y-20">
      {
        categories.map((category) => {
          const publications =
            getPublicationsByCategory(category.id);

          return (
            <section
              id={category.id}
              class="scroll-mt-28"
              aria-labelledby={`${category.id}-heading`}
            >
              <!-- Category heading -->
              <div
                class="mb-8 border-l-4 border-blue-600 pl-4"
              >
                <div
                  class="flex flex-wrap items-end justify-between gap-4"
                >
                  <div>
                    <h2
                      id={`${category.id}-heading`}
                      class="text-3xl font-bold text-gray-900"
                    >
                      {category.label}
                    </h2>

                    <p class="mt-2 text-sm text-gray-500">
                      {category.description}
                    </p>
                  </div>

                  <span class="text-sm text-gray-500">
                    {publications.length}{' '}
                    {
                      publications.length === 1
                        ? 'entry'
                        : 'entries'
                    }
                  </span>
                </div>
              </div>

              {
                publications.length > 0 ? (
                  <div>
                    {publications.map((publication) => (
                      <PublicationItem
                        entry={publication}
                      />
                    ))}
                  </div>
                ) : (
                  <div
                    class="rounded-2xl border border-dashed border-gray-200 bg-gray-50 px-6 py-10 text-center"
                  >
                    <p class="text-sm text-gray-500">
                      No{' '}
                      {category.label.toLowerCase()}{' '}
                      have been added yet.
                    </p>
                  </div>
                )
              }
            </section>
          );
        })
      }
    </div>

    {
      allPublications.length === 0 && (
        <div
          class="mt-16 rounded-2xl border border-dashed border-gray-200 bg-gray-50 px-6 py-12 text-center"
        >
          <p class="text-gray-500">
            No publications found. Add Markdown files under
            <code
              class="mx-1 rounded bg-gray-100 px-2 py-1 text-sm"
            >
              src/content/publications/
            </code>
          </p>
        </div>
      )
    }
  </main>

  <!-- Floating Back to Top button -->
  <button
    id="back-to-top"
    type="button"
    aria-label="Back to top"
    title="Back to top"
    class="pointer-events-none fixed bottom-6 right-6 z-50 flex h-12 w-12 translate-y-4 items-center justify-center rounded-full bg-gray-900 text-white opacity-0 shadow-lg transition-all duration-300 hover:-translate-y-1 hover:bg-blue-600 focus:outline-none focus:ring-4 focus:ring-blue-200"
  >
    <ArrowUp className="h-5 w-5" />
  </button>
</Layout>

<script>
  function initializePublicationPage() {
    const page =
      document.querySelector<HTMLElement>(
        '#publication-page-top'
      );

    const backToTopButton =
      document.querySelector<HTMLButtonElement>(
        '#back-to-top'
      );

    if (!page || !backToTopButton) {
      return;
    }

    /*
     * Astro 페이지 전환이나 재초기화 과정에서
     * 이벤트가 중복 등록되는 것을 방지합니다.
     */
    if (
      page.dataset.backToTopInitialized === 'true'
    ) {
      return;
    }

    page.dataset.backToTopInitialized = 'true';

    function updateBackToTopButton() {
      const shouldShow = window.scrollY > 500;

      backToTopButton.classList.toggle(
        'opacity-0',
        !shouldShow
      );

      backToTopButton.classList.toggle(
        'translate-y-4',
        !shouldShow
      );

      backToTopButton.classList.toggle(
        'pointer-events-none',
        !shouldShow
      );

      backToTopButton.classList.toggle(
        'opacity-100',
        shouldShow
      );

      backToTopButton.classList.toggle(
        'translate-y-0',
        shouldShow
      );

      backToTopButton.classList.toggle(
        'pointer-events-auto',
        shouldShow
      );
    }

    backToTopButton.addEventListener(
      'click',
      () => {
        window.scrollTo({
          top: 0,
          behavior: 'smooth',
        });
      }
    );

    window.addEventListener(
      'scroll',
      updateBackToTopButton,
      { passive: true }
    );

    updateBackToTopButton();
  }

  initializePublicationPage();

  document.addEventListener(
    'astro:page-load',
    initializePublicationPage
  );
</script>

<style is:global>
  html {
    scroll-behavior: smooth;
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }
  }
</style>