---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import PublicationItem from '../components/PublicationItem.astro';
import BookItem from '../components/BookItem.astro';
import HonorCard from '../components/HonorCard.astro';
import {
  Award,
  Book,
  BookOpen,
  CheckCircle,
  Clock,
  ExternalLink,
  FileCode,
  FileInput,
  Github,
  ScrollText,
} from 'lucide-react';

/**
 * Publications
 *
 * 현재 Publications 페이지와 동일하게 전체 publication 컬렉션을
 * 최신 연도순으로 정렬합니다.
 */
const papers = (await getCollection('publications')).sort(
  (a, b) => {
    const yearDifference = b.data.year - a.data.year;

    if (yearDifference !== 0) {
      return yearDifference;
    }

    return a.data.title.localeCompare(b.data.title);
  }
);

/**
 * Books
 */
const books = (await getCollection('books')).sort(
  (a, b) => {
    const yearDifference = b.data.year - a.data.year;

    if (yearDifference !== 0) {
      return yearDifference;
    }

    return a.data.title.localeCompare(b.data.title);
  }
);

/**
 * Software의 대표 연도
 *
 * 1. 최상위 year
 * 2. 연결된 논문의 paper.year
 * 3. 둘 다 없으면 0
 */
const getSoftwareYear = (
  software: Awaited<ReturnType<typeof getCollection<'softwares'>>>[number]
) => software.data.year ?? software.data.paper?.year ?? 0;

/**
 * Research Software
 *
 * 현재 software 스키마에는 date 필드가 없으므로
 * year 또는 paper.year를 사용합니다.
 */
const softwares = (
  await getCollection(
    'softwares',
    ({ data }) => data.published
  )
).sort((a, b) => {
  const yearDifference =
    getSoftwareYear(b) - getSoftwareYear(a);

  if (yearDifference !== 0) {
    return yearDifference;
  }

  if (a.data.order !== b.data.order) {
    return a.data.order - b.data.order;
  }

  return a.data.title.localeCompare(b.data.title);
});

/**
 * Patents
 */
const patents = (await getCollection('patents')).sort(
  (a, b) =>
    b.data.date.valueOf() - a.data.date.valueOf()
);

/**
 * Honors
 */
const honors = (await getCollection('honors')).sort(
  (a, b) =>
    b.data.date.valueOf() - a.data.date.valueOf()
);

const sections = [
  {
    id: 'papers',
    title: 'Published Papers',
    key: 'achievements.papers',
    icon: BookOpen,
    count: papers.length,
  },
  {
    id: 'books',
    title: 'Book Chapters',
    key: 'achievements.books',
    icon: Book,
    count: books.length,
  },
  {
    id: 'softwares',
    title: 'Research Software',
    key: 'achievements.softwares',
    icon: FileCode,
    count: softwares.length,
  },
  {
    id: 'patents',
    title: 'Invention Patents',
    key: 'achievements.patents',
    icon: ScrollText,
    count: patents.length,
  },
  {
    id: 'honors',
    title: 'Group Honors',
    key: 'achievements.honors',
    icon: Award,
    count: honors.length,
  },
];

const getApplicationLink = (
  software: (typeof softwares)[number]
) =>
  software.data.links?.website ??
  software.data.links?.demo;
---

<Layout title="Achievements">
  <main
    class="mx-auto max-w-7xl px-4 py-12 sm:py-20"
  >
    <header
      class="mx-auto mb-16 max-w-3xl text-center"
    >
      <h1
        class="mb-4 text-4xl font-bold text-gray-900"
        data-i18n-key="achievements.title"
      >
        Research Achievements
      </h1>

      <p
        class="text-lg text-gray-600"
        data-i18n-key="achievements.subtitle"
      >
        A comprehensive collection of our academic
        publications, software, intellectual property,
        and collective honors.
      </p>
    </header>

    <!-- Navigation pills -->
    <nav
      aria-label="Achievement categories"
      class="sticky top-20 z-30 mb-16 flex flex-wrap justify-center gap-4 rounded-2xl border border-gray-100 bg-white/80 p-4 shadow-sm backdrop-blur"
    >
      {
        sections.map((section) => {
          const Icon = section.icon;

          return (
            <a
              href={`#${section.id}`}
              class="inline-flex items-center gap-2 rounded-full bg-gray-50 px-4 py-2 text-sm font-medium text-gray-600 transition-colors hover:bg-blue-50 hover:text-blue-600"
            >
              <Icon className="h-4 w-4" />

              <span data-i18n-key={section.key}>
                {section.title}
              </span>

              <span
                class="rounded-full bg-white px-2 py-0.5 text-xs text-gray-400 shadow-sm"
              >
                {section.count}
              </span>
            </a>
          );
        })
      }
    </nav>

    <div class="space-y-24">
      <!-- Papers -->
      <section
        id="papers"
        class="scroll-mt-40"
      >
        <div class="mb-8 flex items-center gap-3">
          <BookOpen
            className="h-8 w-8 text-blue-600"
          />

          <h2
            class="text-3xl font-bold text-gray-900"
            data-i18n-key="achievements.papers"
          >
            Published Papers
          </h2>
        </div>

        <div class="grid gap-6">
          {
            papers.map((paper) => (
              <PublicationItem entry={paper} />
            ))
          }

          {
            papers.length === 0 && (
              <p
                class="italic text-gray-500"
                data-i18n-key="achievements.noPapers"
              >
                No papers listed yet.
              </p>
            )
          }
        </div>
      </section>

      <!-- Books -->
      <section
        id="books"
        class="scroll-mt-40"
      >
        <div class="mb-8 flex items-center gap-3">
          <Book className="h-8 w-8 text-blue-600" />

          <h2
            class="text-3xl font-bold text-gray-900"
            data-i18n-key="achievements.books"
          >
            Book Chapters
          </h2>
        </div>

        <div
          class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4"
        >
          {
            books.map((book) => (
              <BookItem entry={book} />
            ))
          }

          {
            books.length === 0 && (
              <p
                class="italic text-gray-500"
                data-i18n-key="achievements.noBooks"
              >
                No book chapters listed yet.
              </p>
            )
          }
        </div>
      </section>

      <!-- Software -->
      <section
        id="softwares"
        class="scroll-mt-40"
      >
        <div class="mb-8 flex items-center gap-3">
          <FileCode
            className="h-8 w-8 text-blue-600"
          />

          <h2
            class="text-3xl font-bold text-gray-900"
            data-i18n-key="achievements.softwares"
          >
            Research Software
          </h2>
        </div>

        <div
          class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3"
        >
          {
            softwares.map((software) => {
              const softwareYear =
                getSoftwareYear(software);

              const applicationLink =
                getApplicationLink(software);

              return (
                <article
                  class="flex h-full flex-col rounded-xl border border-gray-100 bg-white p-6 shadow-sm transition-shadow hover:shadow-md"
                >
                  <div
                    class="mb-4 flex items-start gap-4"
                  >
                    <div
                      class="shrink-0 rounded-lg bg-blue-50 p-3 text-blue-600"
                    >
                      <FileCode className="h-6 w-6" />
                    </div>

                    <div class="min-w-0">
                      <p
                        class="text-sm font-medium text-blue-600"
                      >
                        {software.data.type}
                      </p>

                      <h3
                        class="mt-1 text-lg font-bold text-gray-900"
                        title={software.data.title}
                      >
                        {software.data.title}
                      </h3>
                    </div>
                  </div>

                  <p
                    class="flex-1 text-sm leading-6 text-gray-600"
                  >
                    {software.data.description}
                  </p>

                  {
                    software.data.developers &&
                    software.data.developers.length >
                      0 && (
                      <p
                        class="mt-4 text-sm text-gray-600"
                      >
                        <span
                          class="font-medium text-gray-900"
                          data-i18n-key="achievements.developers"
                        >
                          Developers:
                        </span>{' '}
                        {
                          software.data.developers.join(
                            ', '
                          )
                        }
                      </p>
                    )
                  }

                  <div
                    class="mt-5 flex items-center justify-between gap-3 border-t border-gray-100 pt-4"
                  >
                    <span
                      class="rounded-full bg-gray-50 px-3 py-1 text-xs font-medium text-gray-600"
                    >
                      {software.data.status}
                    </span>

                    {
                      softwareYear > 0 && (
                        <span
                          class="text-sm text-gray-400"
                        >
                          {softwareYear}
                        </span>
                      )
                    }
                  </div>

                  {
                    (
                      software.data.links?.github ||
                      applicationLink
                    ) && (
                      <div
                        class="mt-4 flex flex-wrap gap-3"
                      >
                        {
                          software.data.links
                            ?.github && (
                            <a
                              href={
                                software.data.links
                                  .github
                              }
                              target="_blank"
                              rel="noreferrer"
                              class="inline-flex items-center gap-2 text-sm font-medium text-gray-600 transition hover:text-blue-600"
                            >
                              <Github
                                className="h-4 w-4"
                              />
                              GitHub
                            </a>
                          )
                        }

                        {
                          applicationLink && (
                            <a
                              href={applicationLink}
                              target="_blank"
                              rel="noreferrer"
                              class="inline-flex items-center gap-2 text-sm font-medium text-gray-600 transition hover:text-blue-600"
                            >
                              <ExternalLink
                                className="h-4 w-4"
                              />
                              Website
                            </a>
                          )
                        }
                      </div>
                    )
                  }
                </article>
              );
            })
          }

          {
            softwares.length === 0 && (
              <p
                class="italic text-gray-500"
                data-i18n-key="achievements.noSoftwares"
              >
                No research software listed yet.
              </p>
            )
          }
        </div>
      </section>

      <!-- Patents -->
      <section
        id="patents"
        class="scroll-mt-40"
      >
        <div class="mb-8 flex items-center gap-3">
          <ScrollText
            className="h-8 w-8 text-blue-600"
          />

          <h2
            class="text-3xl font-bold text-gray-900"
            data-i18n-key="achievements.patents"
          >
            Invention Patents
          </h2>
        </div>

        <div class="grid gap-6">
          {
            patents.map((patent) => (
              <article
                class="rounded-xl border border-gray-100 bg-white p-6 shadow-sm transition-shadow hover:shadow-md"
              >
                <div class="flex gap-4">
                  <div class="shrink-0">
                    <div
                      class="rounded-lg bg-amber-50 p-3 text-amber-600"
                    >
                      <ScrollText
                        className="h-6 w-6"
                      />
                    </div>
                  </div>

                  <div class="flex-grow">
                    <div
                      class="mb-2 flex flex-col justify-between gap-2 sm:flex-row sm:items-center"
                    >
                      <h3
                        class="text-lg font-bold text-gray-900"
                      >
                        {patent.data.title}
                      </h3>

                      <span
                        class:list={[
                          'inline-flex items-center gap-1 rounded-full border px-2.5 py-0.5 text-xs font-medium',
                          patent.data.status ===
                            'Granted'
                            ? 'border-green-200 bg-green-50 text-green-700'
                            : patent.data.status ===
                                'Pending'
                              ? 'border-amber-200 bg-amber-50 text-amber-700'
                              : 'border-gray-200 bg-gray-50 text-gray-600',
                        ]}
                      >
                        {
                          patent.data.status ===
                            'Granted' && (
                            <CheckCircle
                              className="h-3 w-3"
                            />
                          )
                        }

                        {
                          patent.data.status ===
                            'Pending' && (
                            <Clock
                              className="h-3 w-3"
                            />
                          )
                        }

                        {
                          patent.data.status ===
                            'Filed' && (
                            <FileInput
                              className="h-3 w-3"
                            />
                          )
                        }

                        {patent.data.status}
                      </span>
                    </div>

                    <div
                      class="mb-2 text-sm text-gray-600"
                    >
                      <span
                        class="font-medium text-gray-900"
                        data-i18n-key="achievements.inventors"
                      >
                        Inventors:
                      </span>{' '}
                      {patent.data.inventors.join(', ')}
                    </div>

                    <div
                      class="flex flex-wrap items-center gap-4 text-sm text-gray-500"
                    >
                      <span
                        class="rounded border border-gray-200 bg-gray-50 px-2 py-0.5 font-mono"
                      >
                        {patent.data.number}
                      </span>

                      <time>
                        {
                          patent.data.date.toLocaleDateString()
                        }
                      </time>
                    </div>
                  </div>
                </div>
              </article>
            ))
          }

          {
            patents.length === 0 && (
              <p
                class="italic text-gray-500"
                data-i18n-key="achievements.noPatents"
              >
                No patents listed yet.
              </p>
            )
          }
        </div>
      </section>

      <!-- Honors -->
      <section
        id="honors"
        class="scroll-mt-40"
      >
        <div class="mb-8 flex items-center gap-3">
          <Award
            className="h-8 w-8 text-blue-600"
          />

          <h2
            class="text-3xl font-bold text-gray-900"
            data-i18n-key="achievements.honors"
          >
            Group Honors
          </h2>
        </div>

        <div
          class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3"
        >
          {
            honors.map((honor) => (
              <HonorCard honor={honor} />
            ))
          }

          {
            honors.length === 0 && (
              <p
                class="italic text-gray-500"
                data-i18n-key="achievements.noHonors"
              >
                No group honors listed yet.
              </p>
            )
          }
        </div>
      </section>
    </div>
  </main>
</Layout>

<style is:global>
  html {
    scroll-behavior: smooth;
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }
  }
</style>