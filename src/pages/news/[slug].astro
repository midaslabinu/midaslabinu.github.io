---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { ArrowLeft, ExternalLink } from 'lucide-react';

export async function getStaticPaths() {
  const newsEntries = await getCollection(
    'news',
    ({ data }) => data.published !== false && data.readMore === true
  );

  return newsEntries.map((entry) => {
    const slug =
      entry.id
        .replace(/\.[^/.]+$/, '')
        .split('/')
        .pop() ?? entry.id;

    return {
      params: {
        slug,
      },
      props: {
        entry,
      },
    };
  });
}

const { entry } = Astro.props;

const { Content } = await render(entry);

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(entry.data.date);
---

<Layout
  title={entry.data.title}
  description={entry.data.summary}
>
  <main class="mx-auto max-w-4xl px-4 py-16 sm:px-6 sm:py-24">
    <a
      href="/news"
      class="inline-flex items-center gap-2 text-sm font-semibold text-blue-600 transition-colors hover:text-blue-700"
    >
      <ArrowLeft className="h-4 w-4" />
      Back to News
    </a>

    <article class="mt-10">
      <header class="border-b border-gray-200 pb-10">
        <time
          datetime={entry.data.date.toISOString()}
          class="text-sm font-medium text-gray-500"
        >
          {formattedDate}
        </time>

        <h1
          class="mt-4 text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl"
        >
          {entry.data.title}
        </h1>

        <p class="mt-5 text-lg leading-8 text-gray-600">
          {entry.data.summary}
        </p>
      </header>

      <div
        class="prose prose-lg mt-10 max-w-none prose-headings:text-gray-900 prose-p:text-gray-700 prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline"
      >
        <Content />
      </div>

      {
        entry.data.links?.view && (
          <div class="mt-12 border-t border-gray-200 pt-8">
            <a
              href={entry.data.links.view}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-full bg-blue-600 px-6 py-3 font-semibold text-white transition-colors hover:bg-blue-700"
            >
              View Related Page
              <ExternalLink className="h-4 w-4" />
            </a>
          </div>
        )
      }
    </article>
  </main>
</Layout>